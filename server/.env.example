NODE_ENV=development
PORT=3001

USE_LOCAL_DB=true
DATABASE_URL=postgresql://muhib:1234567890@localhost:5434/shirt_database?schema=public
DATABASE_URL_LOCAL=postgresql://muhib:1234567890@localhost:5434/shirt_database?schema=public
# DATABASE_URL_REMOTE=postgresql://user:password@host:5432/database?schema=public
# DIRECT_URL=postgresql://user:password@host:5432/database?schema=public

JWT_SECRET=replace-with-a-long-random-string
JWT_EXPIRES=7d
JWT_COOKIE_EXPIRES=90

FRONTEND_URL=http://localhost:3000
CLIENT_URL=http://localhost:3000
# API_BASE_URL=http://localhost:3001

# Required if you want signup, email verification, password reset, or newsletter emails.
# EMAIL_SERVICE=gmail
# EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
# EMAIL_USERNAME=you@example.com
# EMAIL_PASSWORD=your-app-password
# EMAIL_FROM=noreply@example.com

# Optional Stripe checkout support
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_PUBLISHABLE_KEY=pk_test_...

# Optional Google OAuth support
# GOOGLE_CLIENT_ID=your-google-client-id
# GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:3001/api/v1/users/auth/google/callback

# Optional Supabase storage support
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# SUPABASE_SECRET_KEY=your-service-role-key
# SUPABASE_ANON_KEY=your-anon-key
SUPABASE_BUCKET_NAME=products
SUPABASE_PRODUCTS_BUCKET=products
SUPABASE_REVIEWS_BUCKET=reviews
SUPABASE_MESSAGES_BUCKET=messages
