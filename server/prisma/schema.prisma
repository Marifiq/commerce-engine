generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}


model User {
  id                    Int      @id @default(autoincrement())
  name                  String
  email                 String   @unique
  password              String
  role                  String   @default("user")
  passwordResetToken    String?
  passwordResetExpires  DateTime?
  changedPasswordAt     DateTime?
  createdAt             DateTime @default(now())
  cart                  Cart?
  reviews               Review[]
  orders                Order[]
}

model Category {
  id              Int       @id @default(autoincrement())
  name            String    @unique
  image           String?
  discountPercent Float?    @default(0)
  createdAt       DateTime  @default(now())
}

model Product {
  id              Int            @id @default(autoincrement())
  name            String
  description     String?
  price           Float
  category        String
  image           String
  section         String?
  stock           Int            @default(0)
  discountPercent Float?          @default(0)
  createdAt       DateTime       @default(now())
  cartItems       CartItem[]
  reviews         Review[]
  orderItems      OrderItem[]
  media           ProductMedia[]
  offerProducts   OfferProduct[]
}

model ProductMedia {
  id        Int      @id @default(autoincrement())
  productId Int
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  url       String
  type      String   // "image" or "video"
  isPrimary Boolean  @default(false)
  order     Int      @default(0)
  createdAt DateTime @default(now())
}

model Cart {
  id        Int        @id @default(autoincrement())
  userId    Int        @unique
  user      User       @relation(fields: [userId], references: [id])
  items     CartItem[]
  updatedAt DateTime   @updatedAt
}

model CartItem {
  id        Int     @id @default(autoincrement())
  cartId    Int
  cart      Cart    @relation(fields: [cartId], references: [id])
  productId Int
  product   Product @relation(fields: [productId], references: [id])
  quantity  Int
}

model Order {
  id              Int         @id @default(autoincrement())
  userId          Int
  user            User        @relation(fields: [userId], references: [id])
  items           OrderItem[]
  totalAmount     Float
  status          String      @default("pending")
  shippingAddress String?
  paymentMethod   String?
  createdAt       DateTime    @default(now())
}

model OrderItem {
  id        Int     @id @default(autoincrement())
  orderId   Int
  order     Order   @relation(fields: [orderId], references: [id])
  productId Int
  product   Product @relation(fields: [productId], references: [id])
  price     Float
  quantity  Int
}

model Review {
  id         Int      @id @default(autoincrement())
  text       String
  rating     Int
  isApproved Boolean  @default(false)
  images     String[] @default([])
  videos     String[] @default([])
  productId  Int
  product    Product  @relation(fields: [productId], references: [id])
  userId     Int
  user       User     @relation(fields: [userId], references: [id])
  createdAt  DateTime @default(now())
}

model Offer {
  id              Int            @id @default(autoincrement())
  title           String
  description     String?
  discountPercent Float
  targetType      String         // "product", "category", or "all"
  targetId        Int?           // categoryId (null for all products or when using products relation)
  targetName      String?        // category name for display
  startDate       DateTime?
  endDate         DateTime?
  isActive        Boolean        @default(true)
  showBanner      Boolean        @default(false)
  products        OfferProduct[]
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
}

model OfferProduct {
  id        Int      @id @default(autoincrement())
  offerId   Int
  offer     Offer    @relation(fields: [offerId], references: [id], onDelete: Cascade)
  productId Int
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([offerId, productId])
}